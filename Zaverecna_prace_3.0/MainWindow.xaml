<Window x:Class="Zaverecna_prace_3._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Zaverecna_prace_3._0"
        mc:Ignorable="d"
        Title="MainWindow" Height="1080" Width="1920" WindowState="Maximized" MouseDown="Window_MouseDown" Background="Black"> 

    <Grid x:Name="MainGrid" Opacity="1">
        
        <Image x:Name="SceneBackground"
           Stretch="Fill"/>
        
        <Canvas x:Name="SceneCanvas"
                Background="Transparent"
                MouseMove="SceneCanvas_MouseMove">
            

            <TextBlock x:Name="HoverText"
       Visibility="Collapsed"
       Background="#AA000000"
       Foreground="White"
       Padding="6"
       IsHitTestVisible="False"
       FontSize="14"
           Canvas.ZIndex="999"
           Height="50px"
           Width="150px"/>
        </Canvas>

        <ItemsControl x:Name="InventoryDisplay" 
              HorizontalAlignment="Right" 
              VerticalAlignment="Top" 
              Margin="20"
              Background="#AA000000">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Border x:Name="DialogueBox"
Background="#CC000000"
Height="120"
VerticalAlignment="Bottom"
Margin="20"
Padding="10"
Visibility="Collapsed">

            <StackPanel>
                <TextBlock x:Name="SpeakerText"
           Foreground="LightBlue"
           FontWeight="Bold"
           FontSize="16"/>

                <TextBlock x:Name="DialogueText"
           Foreground="White"
           FontSize="14"
           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

    </Grid>

</Window>
